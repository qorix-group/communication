title Send Data

actor User
participant "OfferedProducer<R>" as OfferedProducer
participant "Publisher<T, R>" as Publisher
participant "SampleMaybeUninit<T>" as SampleMaybeUninit
participant "SampleMut<T>" as SampleMut

User -> OfferedProducer: event_name
OfferedProducer --> User: Publisher<T, R>

User -> Publisher: allocate()
Publisher --> User: Result<SampleMaybeUninit<T>>

alt Allocation Successful
    User -> SampleMaybeUninit: write(value: T)
    SampleMaybeUninit --> User: SampleMut<T>

    Note over SampleMaybeUninit: Data written to\nuninitialized memory

    User -> SampleMut: send()
    SampleMut --> User: Result<()>

else Allocation Failed (AllocateFailed)
    Publisher --> User: Result::Err(AllocateFailed)
    Note over User: Handle error
    Note over User: Buffer full or\nno memory available
end

@enduml
