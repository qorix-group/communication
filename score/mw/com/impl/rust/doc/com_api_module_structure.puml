skinparam backgroundColor #FAFAFA
skinparam defaultFontSize 12
skinparam ArrowColor #333333
skinparam packageStyle rectangle
skinparam defaultTextAlignment center

rectangle "User Application Code" as APP #E1F5FE

rectangle "com-api\n(re-exports & facade)" as FACADE #C8E6C9

rectangle "Runtimes" as RUNTIMES {
  rectangle "com-api-runtime-lola\n(LoLa implementation)" as RUNTIME_LOLA #FFCCBC
  rectangle "com-api-runtime-mock\n(mock implementation)" as RUNTIME_MOCK #FFCCBC
}

rectangle "Abstraction" as ABSTRACTION {
  rectangle "com-api-concept\n(traits & types)" as CONCEPT #C8E6C9
  rectangle "com-api-concept-macros\n(derive macros)" as MACROS #C8E6C9
}

rectangle "com-api-ffi-lola\n(C++/Rust FFI bridge)" as FFI #FFE0B2

rectangle "MW::COM (LoLa) C++ Library" as CPP #D1C4E9

APP --> FACADE : uses
FACADE --> RUNTIME_LOLA : instantiates
FACADE --> RUNTIME_MOCK : instantiates (test)
FACADE --> CONCEPT : depends on
RUNTIME_LOLA --> CONCEPT : implements
RUNTIME_MOCK --> CONCEPT : implements
RUNTIME_LOLA --> FFI : calls via
CONCEPT --> MACROS : uses
FFI --> CPP : invokes

@enduml
